# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# BASE DE DATOS
# ===========================================
# Para desarrollo local (MySQL local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=icon_medellin
DB_USER=root
DB_PASSWORD=

# Para producción (Render, Railway, etc.)
# Puedes usar DATABASE_URL en lugar de las variables individuales:
# DATABASE_URL=mysql://usuario:password@host:puerto/database

# ===========================================
# JWT - SEGURIDAD
# ===========================================
JWT_ACCESS_SECRET=tu_secreto_super_seguro_para_access_token
JWT_REFRESH_SECRET=tu_secreto_super_seguro_para_refresh_token
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ===========================================
# CORS - ORÍGENES PERMITIDOS
# ===========================================
# Para desarrollo: no es necesario, permite localhost automáticamente
# Para producción: lista separada por comas de los dominios permitidos
# Ejemplo: CORS_ORIGINS=https://tunik.vercel.app,https://www.tunik.com
# Para permitir todo (solo desarrollo): CORS_ORIGINS=*
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
